<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_hero"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_ranks"
            app:tint="#FFFFFF"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tournament results"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/bannerWin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_hero"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_nav_ranks"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You won the tournament!"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+3 tokens · +10 bonus stars · regular stars"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:alpha="0.85"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bannerLoss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_ranks"
                    app:tint="@color/text_mute"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finalist"
                        android:textColor="@color/text"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Regular match stars"
                        android:textColor="@color/text_mute"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bannerElim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_profile"
                    app:tint="@color/text_mute"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Eliminated in semifinal"
                    android:textColor="@color/text_mute"
                    android:textSize="15sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1st PLACE"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_hero"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/ivWinnerAvatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_nav_profile"
                    android:background="@drawable/bg_chip"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWinnerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Winner"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvWinnerLeague"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="League"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:alpha="0.85"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_nav_ranks"
                    app:tint="#FFFFFF"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2nd PLACE"
                android:textColor="@color/text_mute"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/ivFinalistAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_nav_profile"
                    android:background="@drawable/bg_chip"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFinalistName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finalist"
                        android:textColor="@color/text"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvFinalistLeague"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="League"
                        android:textColor="@color/text_mute"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEMIFINALISTS"
                android:textColor="@color/text_mute"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/ivSf1Avatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_nav_profile"
                        android:background="@drawable/bg_chip"
                        android:padding="3dp"
                        android:scaleType="fitCenter"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvSf1Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_mute"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvSf1League"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_mute"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivSf2Avatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_nav_profile"
                        android:background="@drawable/bg_chip"
                        android:padding="3dp"
                        android:scaleType="fitCenter"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvSf2Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_mute"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvSf2League"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_mute"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_elev"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoHome"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Back to home"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/accent_ink"
            app:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            app:elevation="0dp"/>
    </LinearLayout>

</LinearLayout>