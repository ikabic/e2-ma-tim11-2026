<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginEnd="12dp">

        <!-- Frame -->
        <ImageView
            android:id="@+id/ivResultRegionAwardFrame"
            android:layout_width="53dp"
            android:layout_height="53dp"
            android:src="@drawable/pfr_bronze"
            android:visibility="gone"
            android:elevation="1dp"/>

        <!-- Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivResultAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:shapeAppearanceOverlay="@style/CircleAppearance"
            tools:srcCompat="@tools:sample/avatars"
            app:strokeColor="@color/border"
            app:strokeWidth="2dp"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Username + league -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvResultUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="username"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivResultLeagueBadge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/league_silver"
                android:layout_marginEnd="4dp"
                android:contentDescription="League" />

            <TextView
                android:id="@+id/tvResultLeague"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silver League"
                android:textColor="@color/league_silver"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Add friend button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddFriend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add"
        android:textColor="@color/accent"
        android:textSize="12sp"
        android:textStyle="bold"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="@color/accent"
        app:strokeWidth="1dp"
        app:cornerRadius="14dp"
        app:elevation="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <!-- Already friends label -->
    <TextView
        android:id="@+id/tvAlreadyFriends"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Friends"
        android:textColor="@color/text_mute"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>