<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/sectionSearching"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_search_people"
            android:contentDescription="Searching"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Searching for tournament opponents..."
            android:textColor="@color/text"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Four players are required for a tournament. Participating costs 3 tokens."
            android:textColor="@color/text_mute"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Cancel"
            android:textColor="@color/text_mute"
            android:textSize="14sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp"
            app:elevation="0dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sectionPairing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOURNAMENT"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Semifinalists"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEMIFINAL A"
            android:textColor="@color/text_mute"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPairA1Avatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_nav_profile"
                    android:background="@drawable/bg_chip"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvPairA1Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvPairA1League"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_mute"
                    android:textSize="11sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="vs"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPairA2Avatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_nav_profile"
                    android:background="@drawable/bg_chip"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvPairA2Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvPairA2League"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_mute"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEMIFINAL B"
            android:textColor="@color/text_mute"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPairB1Avatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_nav_profile"
                    android:background="@drawable/bg_chip"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvPairB1Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvPairB1League"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_mute"
                    android:textSize="11sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="vs"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPairB2Avatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_nav_profile"
                    android:background="@drawable/bg_chip"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvPairB2Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvPairB2League"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_mute"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_hero"
            android:padding="14dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_play_match"
                app:tint="#FFFFFF"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tvYourMatchLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your match: ..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Match will begin in a second..."
            android:textColor="@color/text_mute"
            android:textSize="12sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</FrameLayout>