<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="16dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/tvMissionIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="20sp"
        android:layout_marginEnd="12dp"
        android:text="🎯"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMissionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mission"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvMissionReward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reward: +3 stars"
            android:textColor="@color/text_mute"
            android:textSize="12sp"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivMissionTodo"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_mission_todo"
        app:tint="@color/border"
        android:contentDescription="Not completed"
        android:visibility="visible"/>

    <ImageView
        android:id="@+id/ivMissionDone"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_mission_done"
        app:tint="@color/accent"
        android:contentDescription="Completed"
        android:visibility="gone"/>

</LinearLayout>
