<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_elev">

    <include
        android:id="@+id/header"
        layout="@layout/header_game"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Question Card -->
        <LinearLayout
            android:id="@+id/cardQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_clue_active"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="22dp"
            android:layout_marginBottom="24dp">

            <!-- Question text -->
            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:lineSpacingMultiplier="1.3"
                android:text="Koji je glavni grad Australije?"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Answer Options -->
        <!-- Option A -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswerA"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="A.  Sidnej"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/bg_card"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:icon="@null"/>

        <!-- Option B -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswerB"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="B.  Kanbera"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/bg_card"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:icon="@null"/>

        <!-- Option C -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswerC"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="C.  Melburn"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/bg_card"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:icon="@null"/>

        <!-- Option D -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswerD"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="D.  Brizben"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/bg_card"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:icon="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_gravity="end"
            android:layout_marginBottom="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Skip"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/bg_card"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:icon="@null"/>

        <!-- Round result / feedback banner -->
        <LinearLayout
            android:id="@+id/bannerResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_chip"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivResultIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:src="@drawable/ic_check"
                android:padding="4dp"
                app:tint="@color/accent_ink"
                android:background="@drawable/bg_logo_circle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvResultTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correct answer!"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvResultSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+10 points"
                    android:textColor="@color/accent"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Points delta badge -->
            <TextView
                android:id="@+id/tvPointsDelta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+10"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>