<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <include layout="@layout/header_game"/>

    <!-- Game section (visible during play) -->
    <LinearLayout
        android:id="@+id/sectionGame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <View
                android:id="@+id/progressStep1"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_clue_active"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/progressStep2"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/progressStep3"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/progressStep4"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/progressStep5"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/progressStep6"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/progressStep7"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"/>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/cluesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvStep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLUES · 1/7"
                    android:textColor="@color/text_mute"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/cardClue1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="1"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="?"
                        android:textColor="@color/text"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginStart="12dp"
                        android:textStyle="italic"
                        android:paddingTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClue2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="2"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reveals in 10s"
                        android:textColor="@color/text_dim"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textStyle="italic"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClue3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="3"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reveals in 20s"
                        android:textColor="@color/text_dim"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textStyle="italic"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClue4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="4"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reveals in 30s"
                        android:textColor="@color/text_dim"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textStyle="italic"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClue5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="5"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reveals in 40s"
                        android:textColor="@color/text_dim"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textStyle="italic"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClue6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="6"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue6"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reveals in 50s"
                        android:textColor="@color/text_dim"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textStyle="italic"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClue7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_clue_locked"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:alpha="0.4">

                    <TextView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:text="7"
                        android:gravity="center"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_clue_locked"/>

                    <TextView
                        android:id="@+id/tvClue7"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reveals in 60s"
                        android:textColor="@color/text_dim"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textStyle="italic"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_elev"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="6dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAnswer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:inputType="text"
                    android:hint="Type your guess…"
                    android:textColor="@color/text"
                    android:textColorHint="@color/text_dim"
                    android:textSize="14sp"
                    android:imeOptions="actionDone"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="Submit"
                    android:textColor="@color/accent_ink"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/accent"
                    app:cornerRadius="14dp"
                    app:elevation="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvPointsWorth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/text_mute"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Game over section (hidden until game ends) -->
    <LinearLayout
        android:id="@+id/sectionGameOver"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game over"
            android:textColor="@color/text_mute"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/panelFinalP1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_player_you"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvFinalNameP1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player 1"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvFinalScoreP1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="40sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pts"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VS"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:id="@+id/panelFinalP2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_player_other"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvFinalNameP2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player 2"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvFinalScoreP2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="40sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pts"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvWinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player 1 wins!"
            android:textColor="@color/success"
            android:textSize="20sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>
