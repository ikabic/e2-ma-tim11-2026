<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_hero"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_nav_ranks"
            app:tint="#FFFFFF"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TOURNAMENT · FINAL"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_elev"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvMyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvMyScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text"
                android:textSize="32sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvOpponentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opponent"
                android:textColor="@color/text_mute"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvOpponentScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text"
                android:textSize="32sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_elev"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <View android:id="@+id/dot0" android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_input"/>
        <View android:id="@+id/dot1" android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_input"/>
        <View android:id="@+id/dot2" android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_input"/>
        <View android:id="@+id/dot3" android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_input"/>
        <View android:id="@+id/dot4" android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_input"/>
        <View android:id="@+id/dot5" android:layout_width="0dp" android:layout_height="6dp"
            android:layout_weight="1" android:background="@drawable/bg_input"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"/>

    <LinearLayout
        android:id="@+id/sectionInProgress"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:id="@+id/ivStateIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_play_match"
            android:contentDescription="Game state"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvCurrentGame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FINAL – GAME 1 / 6"
            android:textColor="@color/text_mute"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvGameStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your turn"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="28dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayGame"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Play"
            android:textSize="16sp"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="16dp"
            android:textColor="@color/accent_ink"
            app:elevation="0dp"
            android:visibility="gone"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sectionGameOver"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvFinalResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoHome"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Back to home"
            android:textSize="15sp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            android:textColor="@color/text"
            app:elevation="0dp"/>
    </LinearLayout>

</LinearLayout>