<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_elev"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Rank / Medal -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvRegionRank"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:textColor="@color/text_mute"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip"/>

            <ImageView
                android:id="@+id/tvRegionMedal"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:textSize="22sp"/>
        </FrameLayout>

        <!-- Region icon emoji -->
        <ImageView
            android:id="@+id/ivRegionItemIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>

        <!-- Name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRegionItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Star count -->
        <ImageView
            android:layout_width="16sp"
            android:layout_height="16sp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_star"
            app:tint="@color/accent"/>

        <TextView
            android:id="@+id/tvRegionItemStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>