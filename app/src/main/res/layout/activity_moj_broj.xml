<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <include layout="@layout/header_game"/>

    <LinearLayout
        android:id="@+id/sectionStopTarget"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T A R G E T"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvAnimTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="---"
            android:textColor="@color/accent"
            android:textSize="96sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tap anywhere to stop"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:layout_marginTop="32dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/sectionStopNumbers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T A R G E T"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvTargetNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/target_placeholder"
            android:textColor="@color/accent"
            android:textSize="72sp"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAnimNum1"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tile_normal"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvAnimNum2"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tile_normal"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvAnimNum3"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tile_normal"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvAnimNum4"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tile_normal"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvAnimNum5"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/token"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tile_large"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvAnimNum6"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/token"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tile_large"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tap anywhere to stop"
            android:textColor="@color/text_dim"
            android:textSize="13sp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/sectionPlaying"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T A R G E T"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvTargetNumberPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/target_placeholder"
                android:textColor="@color/accent"
                android:textSize="52sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="12dp"
                android:scrollbars="none"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:id="@+id/llTokens"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp"/>

            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:textColor="@color/text_mute"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvNum1"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/number_placeholder"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tile_normal"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvNum2"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/number_placeholder"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tile_normal"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvNum3"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/number_placeholder"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tile_normal"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvNum4"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/number_placeholder"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tile_normal"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvNum5"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/number_placeholder"
                    android:textColor="@color/token"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tile_normal"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvNum6"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/number_placeholder"
                    android:textColor="@color/token"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tile_large"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="+"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border_strong"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="&#8722;"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border_strong"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMultiply"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/multiply"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border_strong"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDivide"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/divide"
                    android:textColor="@color/text"
                    android:textSize="20sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border_strong"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenParen"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="("
                    android:textColor="@color/text_mute"
                    android:textSize="18sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCloseParen"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text=")"
                    android:textColor="@color/text_mute"
                    android:textSize="18sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackspace"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="&#9003;"
                    android:textColor="@color/danger"
                    android:textSize="18sp"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="C"
                    android:textColor="@color/danger"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/bg_card"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Submit"
                android:textColor="@color/accent_ink"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/accent"
                app:cornerRadius="14dp"
                app:elevation="0dp"
                android:enabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/sectionGameOver"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game over"
            android:textColor="@color/text_mute"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/panelFinalP1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_player_you"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvFinalNameP1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player 1"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvFinalScoreP1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="40sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pts"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VS"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:id="@+id/panelFinalP2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_player_other"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvFinalNameP2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player 2"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvFinalScoreP2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="40sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pts"
                    android:textColor="@color/text_mute"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvWinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player 1 wins!"
            android:textColor="@color/success"
            android:textSize="20sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>
