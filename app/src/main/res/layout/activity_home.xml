<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Persistent header: tokens + stars + spacer + bell -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_elev"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/header">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuestLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log in"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/accent_ink"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            android:visibility="gone"/>

        <!-- Token chip -->
        <LinearLayout
            android:id="@+id/chipTokensHeader"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_chip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_token"
                app:tint="@color/accent"
                android:layout_marginEnd="5dp"
                android:contentDescription="@string/tokens"/>

            <TextView
                android:id="@+id/tvTokenCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" tokens"
                android:textColor="@color/text_mute"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Stars chip -->
        <LinearLayout
            android:id="@+id/chipStarsHeader"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_chip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                app:tint="@color/accent"
                android:layout_marginEnd="5dp"
                android:contentDescription="@string/stars"/>

            <TextView
                android:id="@+id/tvStarCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" stars"
                android:textColor="@color/text_mute"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Friends -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFriends"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            app:icon="@drawable/ic_friends"
            app:iconTint="@color/accent"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@android:color/transparent"
            app:elevation="0dp"
            app:cornerRadius="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            app:icon="@drawable/ic_chat"
            app:iconTint="@color/accent"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="26dp"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@android:color/transparent"
            app:elevation="0dp"
            app:cornerRadius="20dp"/>

        <!-- Bell -->
        <FrameLayout
            android:id="@+id/frameBell"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotifications"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                app:icon="@drawable/ic_notifications"
                app:iconTint="@color/accent"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp"
                android:textSize="18sp"
                android:padding="0dp"
                app:backgroundTint="@android:color/transparent"
                app:elevation="0dp"
                app:cornerRadius="20dp"/>

            <TextView
                android:id="@+id/tvNotifBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_logo_circle"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:text="0"
                android:visibility="visible"/>
        </FrameLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/nestedScroll"
        android:id="@+id/topFrame"/>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:id="@+id/nestedScroll"
        app:layout_constraintTop_toBottomOf="@id/topFrame"
        app:layout_constraintBottom_toTopOf="@id/bottomFrame">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HOME SECTION ===== -->
            <LinearLayout
                android:id="@+id/sectionHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="28dp"
                android:paddingBottom="32dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Greeting -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Welcome back,"
                            android:textColor="@color/text_mute"
                            android:textSize="14sp"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:id="@+id/tvWelcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="player"
                            android:textColor="@color/text"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <!-- Logout Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:padding="0dp"
                        app:icon="@drawable/ic_logout"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/danger"
                        app:backgroundTint="@android:color/transparent"
                        app:elevation="0dp"
                        app:rippleColor="@color/border" />
                </LinearLayout>

                <!-- Hero CTA: orange gradient card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_hero"
                    android:padding="22dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="READY TO COMPETE?"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:alpha="0.78"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start a Match"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play all 6 games against a real opponent"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:alpha="0.82"
                        android:layout_marginBottom="22dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFindMatch"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Find Opponent"
                        android:textColor="#FF7A2F"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#FFFFFF"
                        app:cornerRadius="14dp"
                        app:elevation="0dp"/>
                </LinearLayout>

                <!-- Token info row -->
                <LinearLayout
                    android:id="@+id/rowTokenInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_token"
                        app:tint="@color/accent"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/tokens"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tokens refresh daily · 5 per day"
                        android:textColor="@color/text_mute"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvTokenInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 left"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== GAMES SECTION ===== -->
            <LinearLayout
                android:id="@+id/sectionGames"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="22dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GAMES"
                    android:textColor="@color/text_mute"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardKorakPoKorak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_elev"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Step by step"
                                android:textColor="@color/text"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Guess the word from clues"
                                android:textColor="@color/text_mute"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMojBroj"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_elev"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My number"
                                android:textColor="@color/text"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reach the target using numbers"
                                android:textColor="@color/text_mute"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAsocijacije"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_elev"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Asocijacije"
                                android:textColor="@color/text"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Guess the final word from clues"
                                android:textColor="@color/text_mute"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSkocko"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_elev"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Skocko"
                                android:textColor="@color/text"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Guess the correct combination"
                                android:textColor="@color/text_mute"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardKoZnaZna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_elev"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Who knows, knows"
                                android:textColor="@color/text"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rapid-fire general knowledge trivia"
                                android:textColor="@color/text_mute"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSpojnice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_elev"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Connections"
                                android:textColor="@color/text"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Match related pairs of words or concepts"
                                android:textColor="@color/text_mute"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionRanks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="22dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LEADERBOARD"
                            android:textColor="@color/text_mute"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/tvCycleDateRange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_mute"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRankRefreshCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_mute"
                        android:textSize="11sp"
                        android:text="↻ 2:00"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabWeekly"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Weekly"
                        android:textSize="13sp"
                        android:textColor="@color/accent_ink"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/accent"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp"
                        app:cornerRadius="17dp"
                        app:elevation="0dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabMonthly"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Monthly"
                        android:textSize="13sp"
                        android:textColor="@color/text_mute"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp"
                        app:cornerRadius="17dp"
                        app:elevation="0dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabRegional"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Regional"
                        android:textSize="13sp"
                        android:textColor="@color/text_mute"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp"
                        app:cornerRadius="17dp"
                        app:elevation="0dp"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbRankLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRanking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutRankEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="40dp"
                    android:paddingBottom="40dp"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊"
                        android:textSize="48sp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No players ranked yet"
                        android:textColor="@color/text"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play a match to appear on the leaderboard!"
                        android:textColor="@color/text_mute"
                        android:textSize="14sp"
                        android:gravity="center"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Region section -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/regionFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topFrame"
        app:layout_constraintBottom_toTopOf="@id/bottomFrame"/>

    <!-- Profile section -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/profileFragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topFrame"
        app:layout_constraintBottom_toTopOf="@id/bottomFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom navigation divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:id="@+id/bottomFrame"
        app:layout_constraintTop_toBottomOf="@id/nestedScroll"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"/>

    <!-- Bottom navigation bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:orientation="horizontal"
        android:background="@color/bg_elev"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/bottomNav">

        <!-- Home tab -->
        <LinearLayout
            android:id="@+id/navBtnHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navIconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                app:tint="@color/accent"
                android:contentDescription="Home"/>

            <TextView
                android:id="@+id/navLabelHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Games tab -->
        <LinearLayout
            android:id="@+id/navBtnGames"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navIconGames"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_games"
                app:tint="@color/text_mute"
                android:contentDescription="Games"/>

            <TextView
                android:id="@+id/navLabelGames"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Games"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_mute"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Ranks tab -->
        <LinearLayout
            android:id="@+id/navBtnRanks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navIconRanks"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_ranks"
                app:tint="@color/text_mute"
                android:contentDescription="Ranks"/>

            <TextView
                android:id="@+id/navLabelRanks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ranks"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_mute"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Regions tab -->
        <LinearLayout
            android:id="@+id/navBtnRegions"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navIconRegions"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_regions"
                app:tint="@color/text_mute"
                android:contentDescription="Regions"/>

            <TextView
                android:id="@+id/navLabelRegions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regions"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_mute"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Profile tab -->
        <LinearLayout
            android:id="@+id/navBtnProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navIconProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_profile"
                app:tint="@color/text_mute"
                android:contentDescription="Profile"/>

            <TextView
                android:id="@+id/navLabelProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_mute"
                android:layout_marginTop="3dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
